cat > .gitignore << 'EOF'
# Backend
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/fedxplain.db
backend/logs/
backend/.env
backend/data/raw/creditcard.csv
backend/data/partitioned/*.csv
backend/.pytest_cache/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
EOF