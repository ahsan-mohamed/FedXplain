# Copy this to .env and fill in real values. Never commit the real .env file.

APP_NAME=FedXplain
ENV=development
DEBUG=true

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=sqlite:///./fedxplain.db

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@fedxplain.local
EMAIL_ALERTS_ENABLED=false

MODEL_STORE_DIR=./models_store
FRAUD_ALERT_THRESHOLD=0.85

GROQ_API_KEY=

ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

LOG_LEVEL=INFO
LOG_FILE=./logs/fedxplain.log

MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=1.5
